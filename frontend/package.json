{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,vue,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,vue,css,scss,json,md}\"",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx,vue}\" --fix",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx,vue}\""
  },
  "dependencies": {
    "@unocss/preset-uno": "^66.7.4",
    "@unocss/reset": "^66.7.4",
    "@unocss/vite": "^66.7.4",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.3.0",
    "pinia": "^2.3.1",
    "streamdown": "^2.5.0",
    "unocss": "^66.7.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "eslint-plugin-vue": "9.28.0",
    "globals": "17.0.0",
    "prettier": "3.4.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.33.0",
    "vite": "^6.3.5",
    "vue-eslint-parser": "9.4.3",
    "vue-tsc": "^2.2.8"
  }
