{
  "name": "knowledge-quiz2",
  "version": "1.0.0",
  "description": "Knowledge Quiz 2 - Monorepo",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:reset": "node scripts/reset-databases.js",
    "db:reset:yes": "node scripts/reset-databases.js --yes",
    "db:reset:check": "node scripts/reset-databases.js --check",
    "lint": "pnpm --parallel --filter backend --filter frontend lint"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0"
  }
}
