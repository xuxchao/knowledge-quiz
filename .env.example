# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECTION_STRING=redis://localhost:6379

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_doc
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# ElasticSearch 配置
ELASTICSEARCH_HOST=http://localhost:9200

# ClickHouse 配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=default
CLICKHOUSE_MIGRATION_URL=clickhouse://default@localhost:9000/default
CLICKHOUSE_URL=http://localhost:8123/default
CLICKHOUSE_CLUSTER_ENABLED=false

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Mem0 配置
MEM0_API_KEY=
MEM0_API_URL=http://localhost:8080

# LangFuse 配置
LANGFUSE_SECRET_KEY=langfuse-secret-key
LANGFUSE_PUBLIC_KEY=langfuse-public-key
LANGFUSE_HOST=http://localhost:3005
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minioadmin
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=minioadmin
LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true

# 阿里千问配置
QWEN_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 腾讯云语音配置
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-beijing

# 后端服务配置
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# 前端配置
FRONTEND_PORT=5173
