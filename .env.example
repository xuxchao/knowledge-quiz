# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
LANGFUSE_REDIS_DB=1
REDIS_CONNECTION_STRING=redis://localhost:6379/0

# Mem0 长期记忆配置
MEM0_BASE_URL=http://localhost:8888
MEM0_PUBLIC_API_URL=http://localhost:8888
MEM0_API_KEY=knowledge-doc-mem0-local-api-key
MEM0_TIMEOUT_MS=30000
MEM0_POSTGRES_USER=mem0
MEM0_POSTGRES_PASSWORD=mem0-local-password
MEM0_JWT_SECRET=knowledge-doc-mem0-local-jwt-secret-change-me
MEM0_DASHBOARD_URL=http://localhost:3006
MEM0_TELEMETRY=false

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_doc
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# ElasticSearch 配置
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_CHUNK_INDEX=document_chunks_v2

# ClickHouse 配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_TCP_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=langfuse123
CLICKHOUSE_DB=langfuse
LANGFUSE_CLICKHOUSE_DB=langfuse
CLICKHOUSE_MIGRATION_URL=clickhouse://default:langfuse123@localhost:9000/langfuse
CLICKHOUSE_URL=http://localhost:8123/langfuse
CLICKHOUSE_CLUSTER_ENABLED=false

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_VECTOR_INDEX=document_embeddings_v2
EMBEDDING_DIMENSIONS=1536

# LangFuse 配置
LANGFUSE_SECRET_KEY=langfuse-secret-key
LANGFUSE_PUBLIC_KEY=langfuse-public-key
LANGFUSE_HOST=http://localhost:3005
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://rustfs:9000
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=rustfsadmin
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=rustfsadmin
LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true

# RustFS 配置
RUSTFS_ENDPOINT=http://localhost:9004
RUSTFS_PORT=9004
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=documents
RUSTFS_REGION=us-east-1
RUSTFS_FORCE_PATH_STYLE=true

# 阿里千问配置
QWEN_API_KEY=
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_RERANK_MODEL=gte-rerank-v2
QWEN_RERANK_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# RAG摄取与检索配置
RAG_PARSER_VERSION=2
INGESTION_CONCURRENCY=2
INGESTION_LOCK_DURATION_MS=300000
RAG_MIN_SCORE=0.15
RAG_CONTEXT_TOKEN_BUDGET=6000
RAG_MAX_PAGES=1000
RAG_MAX_CHUNKS=10000
RAG_MAX_TOKENS=2000000
URL_MAX_BYTES=5242880
FFMPEG_PATH=ffmpeg
LIBREOFFICE_PATH=soffice

# 腾讯云语音配置
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-beijing

# 后端服务配置
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# 前端配置
FRONTEND_PORT=5173
